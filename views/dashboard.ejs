<%- include("partials/head") %>
  <%
    const trend = dashboard.charts.dailyTrend;
    const maxTrend = Math.max(1, ...trend.map((item) => item.value));
    const chartWidth = 760;
    const chartHeight = 280;
    const chartPaddingX = 28;
    const chartPaddingY = 26;
    const points = trend.map((item, index) => {
      const x = chartPaddingX + (trend.length === 1 ? 0 : (index * (chartWidth - chartPaddingX * 2)) / (trend.length - 1));
      const y = chartHeight - chartPaddingY - ((item.value / maxTrend) * (chartHeight - chartPaddingY * 2));
      return { ...item, x: Number(x.toFixed(2)), y: Number(y.toFixed(2)) };
    });
    const linePoints = points.map((point) => `${point.x},${point.y}`).join(" ");
    const areaPoints = `${chartPaddingX},${chartHeight - chartPaddingY} ${linePoints} ${chartWidth - chartPaddingX},${chartHeight - chartPaddingY}`;
    const successRate = dashboard.summary.totalRegistrations > 0 ? Math.round((dashboard.summary.emailsSent / dashboard.summary.totalRegistrations) * 100) : 0;
    const topSource = dashboard.charts.sourceMix[0] ? dashboard.charts.sourceMix[0].label : 'No source data yet';
    const topCity = dashboard.charts.cityMix[0] ? dashboard.charts.cityMix[0].label : 'No city data yet';
    const topTicket = dashboard.charts.ticketMix[0] ? dashboard.charts.ticketMix[0].label : 'No ticket data yet';
    const topAttendance = dashboard.charts.attendanceMix[0] ? dashboard.charts.attendanceMix[0].label : 'No mode data yet';
  %>
  <body class="app-body" data-total-registrations="<%= dashboard.summary.totalRegistrations %>">
    <%- include("partials/chrome", { activePage: activePage }) %>

    <main class="app-main">
      <div class="page-wrap">
        <section class="page-header page-header--split">
          <div class="page-copy">
            <span class="eyebrow">Management dashboard</span>
            <h1><%= event.name %></h1>
            <p class="page-description">A responsive operations surface for live registrations, automations, spreadsheet export, certificates, and trend visibility across desktop and mobile.</p>
          </div>
          <div class="status-inline">
            <span class="status-pill status-pill--success"><span class="status-dot"></span><strong><%= dashboard.summary.totalRegistrations === 0 ? 'Ready for launch' : 'Live flow active' %></strong></span>
            <span class="pill"><strong><%= dashboard.summary.growthRate >= 0 ? '+' : '' %><%= dashboard.summary.growthRate %>%</strong> 7 day growth</span>
            <span class="pill" data-sync-status>Monitoring live flow</span>
          </div>
        </section>

        <section class="stats-grid">
          <article class="panel-card stat-card stat-card--soft">
            <span class="stat-label">Total registrations</span>
            <div class="stat-value"><%= dashboard.summary.totalRegistrations %></div>
            <p class="stat-meta"><%= dashboard.summary.todayRegistrations %> new today across all channels.</p>
            <span class="stat-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path><circle cx="9.5" cy="7" r="3"></circle><path d="M20 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16.5 4.13a3 3 0 0 1 0 5.74"></path></svg></span>
          </article>
          <article class="panel-card stat-card stat-card--soft">
            <span class="stat-label">Email success rate</span>
            <div class="stat-value"><%= successRate %>%</div>
            <p class="stat-meta"><%= dashboard.summary.emailsSent %> registration confirmations processed.</p>
            <div class="progress-rail"><div class="progress-fill" style="width: <%= successRate %>%;"></div></div>
          </article>
          <article class="panel-card stat-card stat-card--soft">
            <span class="stat-label">Certificates generated</span>
            <div class="stat-value"><%= dashboard.summary.certificatesGenerated %></div>
            <p class="stat-meta">Generated automatically for confirmed attendees.</p>
            <span class="stat-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 21h10"></path><path d="M12 17v4"></path><path d="M6 3h12"></path><path d="M7 3v7a5 5 0 1 0 10 0V3"></path></svg></span>
          </article>
          <article class="panel-card stat-card stat-card--primary">
            <span class="stat-label">Remaining seats</span>
            <div class="stat-value"><%= dashboard.summary.remainingCapacity %></div>
            <p class="stat-meta">Capacity <%= event.capacity %>. Fill rate is <%= dashboard.summary.fillRate %>%.</p>
          </article>
        </section>

        <section class="dashboard-grid">
          <article class="panel-card chart-card">
            <div class="chart-head">
              <div>
                <span class="card-eyebrow">Registration trends</span>
                <h2 class="panel-title">Daily intake visibility</h2>
              </div>
              <div class="chart-controls">
                <span class="control-pill">Daily</span>
                <span class="control-pill is-active">2 weeks</span>
              </div>
            </div>
            <div class="chart-shell">
              <svg viewBox="0 0 <%= chartWidth %> <%= chartHeight %>" class="trend-chart" role="img" aria-label="Registration trend line chart">
                <defs>
                  <linearGradient id="trendStroke" x1="0%" x2="100%" y1="0%" y2="0%">
                    <stop offset="0%" stop-color="currentColor"></stop>
                    <stop offset="100%" stop-color="#5f90ff"></stop>
                  </linearGradient>
                </defs>
                <% [0.25, 0.5, 0.75].forEach((mark) => { const y = chartHeight - chartPaddingY - (mark * (chartHeight - chartPaddingY * 2)); %>
                  <line x1="<%= chartPaddingX %>" y1="<%= y %>" x2="<%= chartWidth - chartPaddingX %>" y2="<%= y %>" class="chart-grid"></line>
                <% }) %>
                <polygon points="<%= areaPoints %>" class="chart-area"></polygon>
                <polyline points="<%= linePoints %>" class="chart-line"></polyline>
                <% points.forEach((point) => { %>
                  <circle cx="<%= point.x %>" cy="<%= point.y %>" r="4.5" class="chart-point"></circle>
                <% }) %>
              </svg>
              <div class="axis-row">
                <% trend.forEach((item) => { %>
                  <span><%= item.label %></span>
                <% }) %>
              </div>
            </div>
          </article>

          <div class="dashboard-stack">
            <article class="panel-card">
              <div class="panel-head">
                <div>
                  <span class="card-eyebrow">Quick controls</span>
                  <h2 class="panel-title">Operations</h2>
                </div>
              </div>
              <div class="summary-list">
                <div class="summary-item">
                  <span>Email service</span>
                  <strong><%= emailConfigured ? 'SMTP live' : 'Preview logging' %></strong>
                </div>
                <div class="summary-item">
                  <span>Top source</span>
                  <strong><%= topSource %></strong>
                </div>
                <div class="summary-item">
                  <span>Top city</span>
                  <strong><%= topCity %></strong>
                </div>
                <div class="summary-item">
                  <span>Event location</span>
                  <a class="map-link" href="<%= mapUrl %>" target="_blank" rel="noreferrer">Open Google Maps</a>
                </div>
              </div>
              <div class="stack-actions" style="margin-top: 18px;">
                <% if (dashboard.recentRegistrations.length > 0) { %>
                  <form method="post" action="/actions/certificates/regenerate" target="_blank" class="stack-actions" style="width: 100%;">
                    <input type="hidden" name="registrationId" value="<%= quickActionRegistrationId %>" />
                    <button class="button button--primary button--full" type="submit">Trigger latest certificate</button>
                  </form>
                <% } %>
                <a class="button button--ghost button--full" href="/downloads/registrations.xlsx">Export spreadsheet</a>
                <a class="button button--full" href="/automations">Open automations</a>
              </div>
            </article>

            <article class="panel-card">
              <div class="panel-head">
                <div>
                  <span class="card-eyebrow">Resource flow</span>
                  <h2 class="panel-title">Top channels</h2>
                </div>
              </div>
              <div class="insight-grid">
                <div class="insight-card">
                  <span class="stat-label">Ticket leader</span>
                  <strong><%= topTicket %></strong>
                </div>
                <div class="insight-card">
                  <span class="stat-label">Attendance mode</span>
                  <strong><%= topAttendance %></strong>
                </div>
              </div>
            </article>
          </div>
        </section>

        <section class="dashboard-grid dashboard-grid--secondary">
          <article class="panel-card">
            <div class="feed-head">
              <div>
                <span class="card-eyebrow">Recent attendees</span>
                <h2 class="panel-title">Live registration feed</h2>
              </div>
              <a class="button button--ghost button--small" href="/attendees">View all</a>
            </div>

            <div class="feed-list">
              <% if (dashboard.recentRegistrations.length === 0) { %>
                <div class="empty-state">
                  <strong>No registrations yet.</strong>
                  <p>The dashboard is ready. As soon as registrations arrive, email status and certificate downloads will appear here.</p>
                </div>
              <% } %>

              <% dashboard.recentRegistrations.forEach((registration) => { const initials = registration.fullName.split(' ').map((part) => part[0]).slice(0, 2).join('').toUpperCase(); %>
                <article class="feed-row">
                  <div class="feed-identity">
                    <div class="avatar"><%= initials %></div>
                    <div>
                      <div class="feed-name"><%= registration.fullName %></div>
                      <div class="feed-meta"><%= registration.ticketType %> and <%= registration.attendanceMode %> from <%= registration.city || 'Unknown city' %></div>
                    </div>
                  </div>
                  <div class="feed-actions">
                    <span class="status-pill <%= registration.emailSuccessful ? 'status-pill--success' : 'status-pill--warning' %>"><span class="status-dot"></span><strong><%= registration.emailSuccessful ? 'Success' : 'Attention' %></strong></span>
                    <a class="button button--small" href="<%= registration.certificateUrl %>" target="_blank" rel="noreferrer">Download PDF</a>
                  </div>
                </article>
              <% }) %>
            </div>
          </article>

          <article class="panel-card">
            <div class="panel-head">
              <div>
                <span class="card-eyebrow">Visibility</span>
                <h2 class="panel-title">Automation health</h2>
              </div>
            </div>
            <div class="detail-list">
              <div class="detail-item">
                <span>Confirmed registrations</span>
                <strong><%= dashboard.summary.confirmedRegistrations %></strong>
              </div>
              <div class="detail-item">
                <span>Delivery mode</span>
                <strong><%= dashboard.summary.emailMode %></strong>
              </div>
              <div class="detail-item">
                <span>Support email</span>
                <strong><%= event.supportEmail %></strong>
              </div>
            </div>
          </article>
        </section>
      </div>
    </main>

    <script src="/js/app.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/dashboard.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>

