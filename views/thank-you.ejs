<%- include("partials/head") %>
  <body class="app-body">
    <%- include("partials/chrome", { activePage: activePage }) %>

    <main class="app-main">
      <div class="page-wrap shell-center">
        <section class="panel-card center-card">
          <span class="eyebrow">Registration confirmed</span>
          <h1>Seat secured for <%= registration.fullName %></h1>
          <p class="page-description">The attendee has been stored, the certificate workflow has completed, and the confirmation pipeline has been processed.</p>

          <div class="confirmation-grid">
            <article class="detail-card">
              <span>Registration ID</span>
              <strong><%= registration.registrationId %></strong>
            </article>
            <article class="detail-card">
              <span>Email status</span>
              <strong><%= registration.emailStatus %></strong>
            </article>
            <article class="detail-card">
              <span>Ticket type</span>
              <strong><%= registration.ticketType %></strong>
            </article>
            <article class="detail-card">
              <span>Mode</span>
              <strong><%= registration.attendanceMode %></strong>
            </article>
          </div>

          <div class="callout">
            <% if (emailConfigured) { %>
              A confirmation email has been processed for <strong><%= registration.email %></strong> and the certificate is ready to download.
            <% } else { %>
              SMTP is not configured yet, so the confirmation was captured in preview-log mode while the registration still completed successfully.
            <% } %>
          </div>

          <div class="stack-actions" style="margin-top: 22px;">
            <a class="button button--primary" href="/certificates/<%= registration.registrationId %>">Download certificate</a>
            <a class="button" href="/dashboard">Open dashboard</a>
            <a class="button button--ghost" href="/">Register another attendee</a>
          </div>
        </section>
      </div>
    </main>

    <script src="/js/app.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>

