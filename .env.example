NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
APP_NAME=EventFlow Automations

DATA_DIR=./storage
DATABASE_PATH=
WORKBOOK_EXPORT_PATH=
CERTIFICATE_DIR=
EMAIL_LOG_PATH=

EVENT_NAME=FutureProof Summit 2026
EVENT_TAGLINE=Automated registration, confirmations, and reporting in one place
EVENT_DATE=June 18, 2026
EVENT_TIME=09:30 AM - 04:30 PM
EVENT_VENUE=Innovation Hub, Bengaluru
EVENT_CAPACITY=250
EVENT_SUPPORT_EMAIL=events@example.com
EVENT_CERTIFICATE_SIGNER=Program Director
EVENT_TIMEZONE=Asia/Calcutta

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Event Team <no-reply@example.com>
SMTP_REPLY_TO=

FIREBASE_ENABLE_SYNC=true
FIREBASE_ENABLE_AUTH=true
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_REGISTRATIONS_COLLECTION=registrations
FIREBASE_ADMIN_EMAILS=admin@example.com
ADMIN_SESSION_HOURS=12
ADMIN_SESSION_COOKIE_NAME=eventflow_admin_session
